rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /eduportal_kv/{docId} {

      // Public, pre-auth: the schools directory doc (and its chunk pieces,
      // if it ever grows past ~900KB). Needed to validate ?school= links
      // and power the landing-page search before anyone signs in.
      allow read: if docId == 'eduportal_owner_schools'
                   || docId.matches('^eduportal_owner_schools__chunk[0-9]+$');

      // Owner Console: full read/write once signed in with the owner
      // claim. The Owner Console genuinely needs cross-school access
      // (broadcast, sitewide sitemap, moderation queue).
      allow read, write: if request.auth != null
                           && request.auth.token.owner == true;

      // School users: read/write only inside their own school's namespace.
      // schoolPrefix(id) client-side is always 'studymate_<id>_', so every
      // key that school owns starts with that exact prefix — matching the
      // schoolId baked into their custom-auth token.
      allow read, write: if request.auth != null
                           && request.auth.token.schoolId is string
                           && docId.matches('^studymate_' + request.auth.token.schoolId + '_.*$');
    }
  }
}
